rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: get the user's role from Firestore user profiles
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Helper: check if user has a specific role
    function hasRole(role) {
      return isAuth() && getUserRole() == role;
    }

    function hasAnyRole(roles) {
      return isAuth() && getUserRole() in roles;
    }

    // Helper: check if a doctor is accessing their own patient
    function isOwnPatient() {
      return hasRole('Doctor') && resource.data.doctorId == request.auth.uid;
    }

    // === USERS COLLECTION ===
    // Users can read their own profile; admins can read all
    // Any authenticated user may create their own doc (needed if created via Firebase Console)
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || hasRole('Admin'));
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && (request.auth.uid == userId || hasRole('Admin'));
      allow delete: if isAuth() && hasRole('Admin');
    }

    // === PATIENTS COLLECTION ===
    // Admin/Staff see all; doctors only see their assigned patients
    match /patients/{patientId} {
      allow read: if isAuth() && (
        hasAnyRole(['Admin', 'Staff', 'Pharmacist', 'Lab Tech']) ||
        isOwnPatient()
      );
      allow create: if isAuth() && hasAnyRole(['Admin', 'Doctor', 'Staff']);
      allow update: if isAuth() && hasAnyRole(['Admin', 'Doctor', 'Staff']);
      allow delete: if isAuth() && hasRole('Admin');
    }

    // === APPOINTMENTS COLLECTION ===
    // Doctors can only read their own appointments
    match /appointments/{appointmentId} {
      allow read: if isAuth() && (
        hasAnyRole(['Admin', 'Staff']) ||
        (hasRole('Doctor') && resource.data.doctorId == request.auth.uid)
      );
      allow create: if isAuth() && hasAnyRole(['Admin', 'Doctor', 'Staff']);
      allow update: if isAuth() && hasAnyRole(['Admin', 'Doctor', 'Staff']);
      allow delete: if isAuth() && hasRole('Admin');
    }

    // === PRESCRIPTIONS COLLECTION ===
    match /prescriptions/{rxId} {
      allow read: if isAuth() && hasAnyRole(['Admin', 'Doctor', 'Pharmacist']);
      allow create: if isAuth() && hasRole('Doctor');
      allow update: if isAuth() && hasAnyRole(['Doctor', 'Pharmacist']);
      allow delete: if isAuth() && hasRole('Admin');
    }

    // === INVENTORY COLLECTION ===
    match /inventory/{itemId} {
      allow read: if isAuth();
      allow create: if isAuth() && hasRole('Admin');
      allow update: if isAuth() && hasAnyRole(['Admin', 'Pharmacist']);
      allow delete: if isAuth() && hasRole('Admin');
    }

    // === LAB_ORDERS COLLECTION ===
    match /lab_orders/{orderId} {
      allow read: if isAuth() && hasAnyRole(['Admin', 'Doctor', 'Lab Tech']);
      allow create: if isAuth() && hasRole('Doctor');
      allow update: if isAuth() && hasAnyRole(['Lab Tech', 'Doctor']);
      allow delete: if isAuth() && hasRole('Admin');
    }

    // === LAB_RESULTS COLLECTION ===
    match /lab_results/{resultId} {
      allow read: if isAuth() && hasAnyRole(['Admin', 'Doctor', 'Lab Tech', 'Pharmacist']);
      allow create: if isAuth() && hasRole('Lab Tech');
      allow update: if isAuth() && hasRole('Lab Tech');
      allow delete: if isAuth() && hasRole('Admin');
    }

    // === TRANSACTIONS (Billing/UPI) COLLECTION ===
    match /transactions/{txnId} {
      allow read: if isAuth() && hasAnyRole(['Admin', 'Pharmacist', 'Staff']);
      allow create: if isAuth() && hasAnyRole(['Admin', 'Pharmacist', 'Staff']);
      allow update: if isAuth() && hasAnyRole(['Admin', 'Pharmacist']);
      allow delete: if isAuth() && hasRole('Admin');
    }

    // === INVOICES COLLECTION ===
    match /invoices/{invoiceId} {
      allow read: if isAuth() && hasAnyRole(['Admin', 'Pharmacist', 'Staff']);
      allow create: if isAuth() && hasAnyRole(['Admin', 'Pharmacist', 'Staff']);
      allow update: if isAuth() && hasAnyRole(['Admin', 'Pharmacist']);
      allow delete: if isAuth() && hasRole('Admin');
    }

    // === AUDIT_LOGS COLLECTION ===
    // Append-only; any authenticated user can write, only admins can read
    match /audit_logs/{logId} {
      allow read: if isAuth() && hasRole('Admin');
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // === STAFF (Personnel) COLLECTION ===
    // Any authenticated user can read; only Admin can write
    match /staff/{staffId} {
      allow read: if isAuth();
      allow create: if isAuth() && hasRole('Admin');
      allow update: if isAuth() && hasRole('Admin');
      allow delete: if isAuth() && hasRole('Admin');
    }

    // === OPD_QUEUE COLLECTION ===
    match /opd_queue/{entryId} {
      allow read: if isAuth() && hasAnyRole(['Admin', 'Doctor', 'Staff']);
      allow create: if isAuth() && hasAnyRole(['Admin', 'Staff']);
      allow update: if isAuth() && hasAnyRole(['Admin', 'Doctor', 'Staff']);
      allow delete: if isAuth() && hasRole('Admin');
    }

    // === STAFF SCHEDULES COLLECTION ===
    match /staff_schedules/{scheduleId} {
      allow read: if isAuth();
      allow write: if isAuth() && hasRole('Admin');
    }

    // === HEAD OF STAFF (current + history) COLLECTIONS ===
    match /head_of_staff/{hosId} {
      allow read: if isAuth();
      allow write: if isAuth() && hasRole('Admin');
    }

    match /head_of_staff_history/{historyId} {
      allow read: if isAuth() && hasAnyRole(['Admin', 'Staff']);
      allow create: if isAuth() && hasRole('Admin');
      allow update: if false;
      allow delete: if false;
    }

    // === PURCHASE REQUISITIONS COLLECTION ===
    match /purchase_requisitions/{prId} {
      allow read: if isAuth() && hasAnyRole(['Admin', 'Pharmacist']);
      allow create: if isAuth() && hasAnyRole(['Admin', 'Pharmacist']);
      allow update: if isAuth() && hasAnyRole(['Admin', 'Pharmacist']);
      allow delete: if isAuth() && hasRole('Admin');
    }

    // === NOTIFICATIONS COLLECTION ===
    match /notifications/{notifId} {
      allow read: if isAuth();
      allow create: if isAuth() && hasAnyRole(['Admin', 'Pharmacist', 'Staff']);
      allow delete: if isAuth() && hasAnyRole(['Admin', 'Pharmacist']);
      allow update: if false;
    }

    // === WARDS + BEDS COLLECTION ===
    match /wards/{wardId} {
      allow read: if isAuth() && hasAnyRole(['Admin', 'Staff']);
      allow write: if isAuth() && hasAnyRole(['Admin', 'Staff']);
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
